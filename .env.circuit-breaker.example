# =============================================================================
# OpenAI Circuit Breaker Configuration
# =============================================================================
# Add these to your .env.local file
#
# See docs/CIRCUIT_BREAKER_DESIGN.md for detailed documentation
# See CIRCUIT_BREAKER_IMPLEMENTATION.md for integration guide

# =============================================================================
# CIRCUIT BREAKER THRESHOLDS
# =============================================================================

# Error rate (0-1) that triggers OPEN state
# Default: 0.5 (50% error rate opens circuit)
# Strict (production): 0.5
# Lenient (dev): 0.7
OPENAI_ERROR_THRESHOLD=0.5

# Consecutive failures that triggers OPEN state
# Default: 3 (3 consecutive errors opens circuit)
# Strict (production): 3
# Lenient (dev): 5
OPENAI_CONSECUTIVE_FAILURES=3

# =============================================================================
# RECOVERY CONFIGURATION
# =============================================================================

# Time (milliseconds) before attempting recovery (OPEN → HALF_OPEN)
# Default: 60000 (60 seconds)
# Quick recovery (dev): 30000
# Slow recovery (conservative): 120000
OPENAI_RECOVERY_TIMEOUT=60000

# Number of successful API calls in HALF_OPEN to close circuit (HALF_OPEN → CLOSED)
# Default: 2 (2 successful calls closes circuit)
# Lenient (faster recovery): 1
# Strict (more testing): 3
OPENAI_HALF_OPEN_ATTEMPTS=2

# =============================================================================
# METRICS TRACKING
# =============================================================================

# Window of recent calls to track for error rate calculation
# Default: 100 (track last 100 calls)
# Larger window: 500 (more stable metrics)
# Smaller window: 50 (faster response to changes)
OPENAI_METRICS_WINDOW=100

# Interval (milliseconds) to reset metrics when stable
# Default: 300000 (5 minutes)
# Allows old failures to be forgotten after prolonged stability
OPENAI_METRICS_RESET_INTERVAL=300000

# =============================================================================
# FALLBACK STRATEGY CONFIGURATION
# =============================================================================

# Use fallback cache for degraded extractions
# Default: true
# Set to false to disable cache-based fallback (use rules only)
OPENAI_USE_FALLBACK_CACHE=true

# Use rule-based fallback when cache misses
# Default: true
# Set to false to return empty results instead of pattern-based extraction
OPENAI_FALLBACK_USE_RULES=true

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Enable detailed circuit breaker logging
# Default: true (log state transitions and events)
# Set to false in production to reduce logs
OPENAI_CIRCUIT_DEBUG=true

# Log health metrics to database
# Default: true (save metrics for historical analysis)
# Set to false to skip database logging (performance optimization)
OPENAI_LOG_HEALTH_METRICS=true

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================

# Interval (milliseconds) for health check cron job
# Default: 300000 (5 minutes)
# More frequent: 120000 (2 minutes) - faster alerts
# Less frequent: 600000 (10 minutes) - fewer database writes
OPENAI_HEALTH_CHECK_INTERVAL=300000

# Alert threshold for error rate (0-1)
# When error rate exceeds this, trigger warning alert
# Default: 0.7 (alert at 70% errors)
OPENAI_ALERT_ERROR_RATE=0.7

# Send alerts when circuit opens
# Default: true
OPENAI_ALERT_CIRCUIT_OPEN=true

# =============================================================================
# SLACK INTEGRATION (Optional)
# =============================================================================

# Webhook URL for Slack alerts
# Get from: https://api.slack.com/apps/YOUR_APP/incoming-webhooks
# Leave empty to disable Slack alerts
SLACK_WEBHOOK_URL=

# =============================================================================
# RECOMMENDED PROFILES
# =============================================================================

# ============= PRODUCTION (Strict, Reliable) =============
# OPENAI_ERROR_THRESHOLD=0.5
# OPENAI_CONSECUTIVE_FAILURES=3
# OPENAI_RECOVERY_TIMEOUT=120000
# OPENAI_HALF_OPEN_ATTEMPTS=3
# OPENAI_CIRCUIT_DEBUG=false
# OPENAI_LOG_HEALTH_METRICS=true

# ============= DEVELOPMENT (Lenient, Fast) =============
# OPENAI_ERROR_THRESHOLD=0.7
# OPENAI_CONSECUTIVE_FAILURES=5
# OPENAI_RECOVERY_TIMEOUT=30000
# OPENAI_HALF_OPEN_ATTEMPTS=1
# OPENAI_CIRCUIT_DEBUG=true
# OPENAI_LOG_HEALTH_METRICS=true

# ============= TESTING (Very Lenient) =============
# OPENAI_ERROR_THRESHOLD=0.9
# OPENAI_CONSECUTIVE_FAILURES=10
# OPENAI_RECOVERY_TIMEOUT=5000
# OPENAI_HALF_OPEN_ATTEMPTS=1
# OPENAI_CIRCUIT_DEBUG=true
# OPENAI_LOG_HEALTH_METRICS=false

# =============================================================================
# NOTES
# =============================================================================

# After setting these values:
# 1. Apply database migration: MIGRATION_CIRCUIT_BREAKER.sql
# 2. Update src/services/topic-processor.ts to pass supabase
# 3. Test health endpoint: curl http://localhost:3000/api/health/circuit-breaker
# 4. Set up cron job for health checks (every 5 minutes)
# 5. Monitor with: curl http://localhost:3000/api/health/circuit-breaker | jq .

# More info:
# - Design: docs/CIRCUIT_BREAKER_DESIGN.md
# - Implementation: CIRCUIT_BREAKER_IMPLEMENTATION.md
# - API Docs: src/app/api/health/circuit-breaker/route.ts
