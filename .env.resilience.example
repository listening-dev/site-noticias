# OpenAI Resilience Wrapper Configuration
# Copy to .env.local and adjust values as needed

# === Retry Configuration ===
# Number of retries for transient errors (429, 5xx, timeout)
OPENAI_MAX_RETRIES=3

# Initial delay for exponential backoff (milliseconds)
# Actual delays: 100ms, 200ms, 400ms, 800ms, ...
OPENAI_INITIAL_DELAY_MS=100

# Maximum timeout per request (milliseconds)
OPENAI_TIMEOUT_MS=30000

# === Token Budget Configuration ===
# Daily token limit (prevents hitting rate limits)
# Free tier: ~100,000 tokens/day
# Paid tier: adjust based on your plan
OPENAI_TOKEN_BUDGET_DAILY=100000

# Minimum token headroom to keep in reserve (milliseconds)
# When tokens < headroom, requests may be throttled
# Default: 1000 tokens (~6 requests for avg 165 tokens/request)
OPENAI_TOKEN_BUDGET_MIN_HEADROOM=1000

# Enable token budget enforcement
OPENAI_ENABLE_TOKEN_BUDGET=true

# === Resilience Features ===
# Enable request deduplication for concurrent identical requests
# Prevents duplicate API calls when same request made multiple times simultaneously
OPENAI_ENABLE_DEDUP=true

# Enable adaptive timeout based on API health
# Reduces timeout if API is experiencing slow responses (fail-fast)
OPENAI_ENABLE_ADAPTIVE_TIMEOUT=true

# === Logging ===
# Enable detailed debug logging for resilience wrapper
# Use 'debug' or 'trace' for detailed output, 'info' for normal, 'warn' for errors only
LOG_LEVEL=info
